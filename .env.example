# AlphaTrades Environment Variables
# Copy this file to .env for local development

# Database (Render provides this automatically)
DATABASE_URL=postgresql://localhost/alphatrades

# Alpaca API (Paper Trading - get keys at https://app.alpaca.markets)
ALPACA_API_KEY=your_paper_key_here
ALPACA_SECRET_KEY=your_secret_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets

# Trading mode
TRADING_MODE=paper  # paper or live

# Auto-trade configuration (optional, overrides database config)
# AUTO_TRADE_GRADES=A+,A
# POSITION_SIZE_PCT=0.20
# MAX_POSITIONS=3
