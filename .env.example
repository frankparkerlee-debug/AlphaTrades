# AlphaTrades Environment Variables
# Copy this file to .env for local development

# Database (Render provides this automatically)
DATABASE_URL=postgresql://localhost/alphatrades

# Finnhub API (get free key at https://finnhub.io)
FINNHUB_API_KEY=your_key_here

# Trading mode
TRADING_MODE=paper  # paper or live

# Auto-trade configuration (optional, overrides database config)
# AUTO_TRADE_GRADES=A+,A
# POSITION_SIZE_PCT=0.20
# MAX_POSITIONS=3
